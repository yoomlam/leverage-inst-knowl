# Copy to .env and edit. Swapping the test DB for the real one is a credentials
# change here, not a code change.
LIK_DB_HOST=localhost
LIK_DB_PORT=5432
LIK_DB_NAME=likdb_test   # the test suite refuses any name not ending in _test
# For manual testing, point the server at the persistent local DB instead:
#   LIK_DB_NAME=likdb_local  (create once: see README "Local database")
LIK_DB_USER=lik
LIK_DB_PASSWORD=lik
LIK_DB_SSLMODE=prefer

# local | test -> StubAuthenticator (no real identity check). Anything else requires
# real Google OAuth (below) and refuses to start without it.
LIK_ENV=local

# --- OAuth (only outside local/test) ---------------------------------------
# The Google OAuth client id the agent's tokens are minted for; an incoming token must
# carry this as its audience. Required when LIK_ENV is not local/test.
# LIK_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# This server's own public URL (resource identifier for OAuth metadata discovery).
# LIK_RESOURCE_SERVER_URL=https://lik.example.com/mcp
# Scopes a token must carry (the OAuth consent must request these). Default: openid,email
# LIK_OAUTH_REQUIRED_SCOPES=openid,email
