# Copy to .env and edit. Swapping the test DB for the real one is a credentials
# change here, not a code change.
LIK_DB_HOST=localhost
LIK_DB_PORT=5432
LIK_DB_NAME=likdb_test   # the test suite refuses any name not ending in _test
# For manual testing, point the server at the persistent local DB instead:
#   LIK_DB_NAME=likdb_local  (create once: see README "Local database")
LIK_DB_USER=lik
LIK_DB_PASSWORD=lik
LIK_DB_SSLMODE=prefer

# local | test -> StubVerifier (no real identity check). Anything else -> fail-closed.
LIK_ENV=local
