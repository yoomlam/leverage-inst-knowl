# Copy to .env and edit. All config is LIK_UI_-prefixed. Secrets stay here / in the
# environment and are never committed or logged.

# local | test -> stubbed identity + vault (no real auth). Anything else requires the
# app-login, vault, and agent config below and refuses to start without it.
LIK_UI_ENV=local

# --- Postgres (lik-ui's own store) --------------------------------------------
LIK_UI_DB_HOST=localhost
LIK_UI_DB_PORT=5432
LIK_UI_DB_NAME=likuidb_test   # the test suite refuses any name not ending in _test
LIK_UI_DB_USER=lik
LIK_UI_DB_PASSWORD=lik
LIK_UI_DB_SSLMODE=prefer

# --- HTTP serving -------------------------------------------------------------
LIK_UI_HTTP_HOST=127.0.0.1
LIK_UI_HTTP_PORT=8001
LIK_UI_APP_BASE_URL=http://localhost:8001
# Strong random value; signs the session cookie. Required outside local/test.
# LIK_UI_SESSION_SECRET=change-me-to-a-long-random-string

# --- App login: identity-only Google OIDC client (separate from data sources) -
# LIK_UI_APP_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# LIK_UI_APP_OAUTH_CLIENT_SECRET=xxxxx

# --- lik-mcp data connection: pre-configured Google client (no DCR) -----------
# Reuse lik-mcp's LIK_OAUTH_CLIENT_ID verbatim (it is the token audience lik-mcp checks).
# LIK_UI_LIKMCP_CLIENT_ID=xxxxx.apps.googleusercontent.com
# LIK_UI_LIKMCP_CLIENT_SECRET=xxxxx
# Must exactly equal lik-mcp's LIK_RESOURCE_SERVER_URL (credential is keyed by this URL).
# LIK_UI_LIKMCP_RESOURCE_URL=https://lik.example.com/mcp

# --- Google Drive data connection: pre-configured Google client (no DCR) ------
# Same shape as lik-mcp: Google is the AS (no DCR), so the client is pre-configured and
# keyed by the MCP server URL the agent declares. RESOURCE_URL must equal that URL.
# LIK_UI_GDRIVEMCP_CLIENT_ID=xxxxx.apps.googleusercontent.com
# LIK_UI_GDRIVEMCP_CLIENT_SECRET=xxxxx
# LIK_UI_GDRIVEMCP_RESOURCE_URL=https://drivemcp.example.com/mcp

# --- Anthropic / Managed Agents -----------------------------------------------
# LIK_UI_ANTHROPIC_API_KEY=sk-ant-...

# --- Agent registry -----------------------------------------------------------
# Agents to offer, as agent_id:environment_id pairs, comma-separated. The label shown
# for each is read from the agent's own definition via the SDK.
# LIK_UI_AGENTS_CONFIG=agent_01E7mqTKAdtosKpWDSLxALmq:env_016c6vWcCUvyVUaztWhvsAQt
